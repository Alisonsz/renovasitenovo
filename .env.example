# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

ADMIN_NAME="Renova Admin"
ADMIN_EMAIL=admin@renovalaser.local
ADMIN_PASSWORD=change-me

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=renovasitenovo
