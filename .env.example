PAGBANK_PIX_DISCOUNT_PERCENT=5
PAGBANK_MAX_INSTALLMENTS=12
PAGBANK_MIN_INSTALLMENT_CENTS=7800
PAGBANK_INTEREST_FREE_INSTALLMENTS=12
PAGBANK_PIX_EXPIRATION_MINUTES=30
