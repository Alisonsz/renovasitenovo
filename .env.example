PAGBANK_ENV=sandbox
PAGBANK_TOKEN=
PAGBANK_PUBLIC_KEY=
PAGBANK_WEBHOOK_TOKEN=
PAGBANK_NOTIFICATION_URL="${APP_URL}/webhooks/pagbank"
